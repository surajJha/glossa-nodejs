{
  "name": "glossa-nodejs",
  "version": "1.0.1",
  "description": "High-accuracy language detection for Indian languages with same-script disambiguation.",
  "keywords": [
    "language-detection",
    "language-identification",
    "indian-languages",
    "hindi",
    "marathi",
    "bengali",
    "assamese",
    "nlp",
    "script-detection",
    "langdetect"
  ],
  "license": "MIT",
  "author": "Suraj Kumar Jha",
  "homepage": "https://github.com/surajJha/glossa-nodejs#readme",
  "bugs": {
    "url": "https://github.com/surajJha/glossa-nodejs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/surajJha/glossa-nodejs.git"
  },
  "type": "commonjs",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "glossa": "bin/glossa.js"
  },
  "files": [
    "src/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test test/",
    "lint": "find src bin test -name '*.js' -print0 | xargs -0 -n1 node --check",
    "prepack": "npm test && npm run lint"
  }
}
